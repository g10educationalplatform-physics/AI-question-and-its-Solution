  },
"solution_steps": [
  "Step 1: Convert solute mass into mg",
  "\\(0.002\\,g = 2\\,mg\\)",

  "Step 2: Use relation",
  "\\(1\\,ppm \\approx 1\\,mg\\,L^{-1}\\)",

  "Step 3: Calculate concentration",
  "\\(\\frac{2}{500} = 0.004\\,mg\\,L^{-1}\\)",

  "Step 4: Convert into ppm",
  "\\(0.004\\,mg\\,L^{-1} = 0.004\\,ppm\\)",

  "Step 5: Using formula",
  "\\(ppm = \\frac{0.002}{500000} \\times 10^6\\)",

  "\\(= 4\\,ppm\\)",

  "Final Answer: \\(4\\,ppm\\)"
