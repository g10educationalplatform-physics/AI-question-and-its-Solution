  "concept": "Concentration (ppm)",
  "question": {
    "text": "Q1. A water sample contains 0.002 g of lead (Pb²⁺) dissolved in 500 L of water.\nAssuming the density of water = 1 g mL⁻¹, calculate the concentration of lead in ppm.\nUse the relation:\nppm = mass of solute / total mass of solution × 10⁶\nAlso, for dilute aqueous solutions:\n1 ppm ≈ 1 mg L⁻¹",
    "image": null
  },
  "options": [
    { "id": "a", "text": "2 ppm" },
    { "id": "b", "text": "4 ppm" },
    { "id": "c", "text": "0.004 ppm" },
    { "id": "d", "text": "0.04 ppm" }
  ],
  "correct_answer": "b",
  "solution": {
    "text": "ppm = mass of solute / mass of solution × 10⁶",
    "image": null
  },
"solution_steps": [
  "Step 1: Convert solute mass into mg",
  "\\(0.002\\,g = 2\\,mg\\)",

  "Step 2: Use relation",
  "\\(1\\,ppm \\approx 1\\,mg\\,L^{-1}\\)",

  "Step 3: Calculate concentration",
  "\\(\\frac{2}{500} = 0.004\\,mg\\,L^{-1}\\)",

  "Step 4: Convert into ppm",
  "\\(0.004\\,mg\\,L^{-1} = 0.004\\,ppm\\)",

  "Step 5: Using formula",
  "\\(ppm = \\frac{0.002}{500000} \\times 10^6\\)",

  "\\(= 4\\,ppm\\)",

  "Final Answer: \\(4\\,ppm\\)"
]
